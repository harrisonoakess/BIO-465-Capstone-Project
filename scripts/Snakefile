import math
import glob
import csv
import os

configfile: "config.yaml"

FASTA_DIR = config["dirs"]["fasta"]
MSA_DIR = config["dirs"]["msa"]
YAML_DIR = config["dirs"]["yaml"]
INPUT_DIR = config["input_dir"]
BOLTZ_DIR = config["dirs"]["boltz"]
PREDICTIONS_DIR = os.path.join(BOLTZ_DIR, "predictions")

LIGANDS = f"{INPUT_DIR}/ligands/cancer_ligands.csv"
LIGAND_INFO = {}
with open(LIGANDS) as f:
    reader = csv.DictReader(f)
    for row in reader:
        LIGAND_INFO[row["ligand_id"]] = row

BATCH_SIZE = 5

# discover proteins from chunked FASTAs
PROTEINS = glob_wildcards(f"{FASTA_DIR}/{{protein}}.fasta").protein

# load ligand ids
with open(LIGANDS) as f:
    LIGAND_IDS = [row.split(",")[0] for row in f.read().strip().split("\n")[1:]]

print(f"Loaded {len(LIGAND_IDS)} ligands")

# --------------------------------------------------
# Final targets
# --------------------------------------------------

# The new "all" rule points to each protein-ligand folder in predictions
rule all:
    input:
        expand(
            os.path.join(PREDICTIONS_DIR, "{protein}_{ligand}"),
            protein=PROTEINS,
            ligand=LIGAND_IDS
        )

# --------------------------------------------------
# Generate YAML
# --------------------------------------------------

rule generate_yaml:
    input:
        fasta=f"{FASTA_DIR}/{{protein}}.fasta",
        msa=f"{MSA_DIR}/{{protein}}/{{protein}}.a3m"
    output:
        f"{YAML_DIR}/{{protein}}_{{ligand}}.yaml"
    log:
        f"logs/generate_yaml/{{protein}}_{{ligand}}.log"
    params:
        ligand_type=lambda wc: LIGAND_INFO[wc.ligand]["type"],
        ligand_value=lambda wc: LIGAND_INFO[wc.ligand]["value"]
    threads: 1
    resources:
        mem_mb=1000,
        runtime=10,
        partition="granite",
        qos="granite-freecycle",
        account="stewartp"
    shell:
        """
        set -euo pipefail

        python generate_yaml.py \
            --fasta_file {input.fasta} \
            --msa_file {input.msa} \
            --ligand_id {wildcards.ligand} \
            --ligand_type {params.ligand_type} \
            --ligand_value "{params.ligand_value}" \
            --output_yaml {output} \
            > {log} 2>&1
        """

# --------------------------------------------------
# Run Boltz 
# --------------------------------------------------

rule run_boltz:
    input:
        yaml=f"{YAML_DIR}/{{protein}}_{{ligand}}.yaml"
    output:
        directory(os.path.join(PREDICTIONS_DIR, "{protein}_{ligand}"))
    log:
        f"logs/run_boltz_batch/{{protein}}_{{ligand}}.log"
    threads: 4
    resources:
        mem_mb=32000,
        runtime=60,
        gpu=1,
        partition="rai-gpu-grn",
        qos="rai-gpu-grn",
        account="rai"
    shell:
        """
        set -euo pipefail

        scripts/run_boltz.sh \
            {input.yaml} \
            {output} \
            {threads} \
            > {log} 2>&1
        """