import math
import glob
import csv

configfile: "config.yaml"

FASTA_DIR = config["dirs"]["chunks"]
MSA_DIR = config["dirs"]["msa"]
YAML_DIR = config["dirs"]["yaml"]
BOLTZ_DIR = config["dirs"]["boltz"]
INPUT_DIR = config["input_dir"]

LIGANDS = f"{INPUT_DIR}/ligands/cancer_ligands.csv"
LIGAND_INFO = {}
with open(LIGANDS) as f:
    reader = csv.DictReader(f)
    for row in reader:
        LIGAND_INFO[row["ligand_id"]] = row

BATCH_SIZE = 5

# discover proteins from chunked FASTAs
PROTEINS = glob_wildcards(f"{FASTA_DIR}/{{protein}}.fasta").protein

# load ligand ids
with open(LIGANDS) as f:
    LIGAND_IDS = [row.split(",")[0] for row in f.read().strip().split("\n")[1:]]

N_BATCHES = math.ceil(len(LIGAND_IDS) / BATCH_SIZE)
BATCHES = list(range(N_BATCHES))
print(f"Loaded {len(LIGAND_IDS)} ligands across {N_BATCHES} batches")

# --------------------------------------------------
# Final targets
# --------------------------------------------------

rule all:
    input:
        expand(
            f"{BOLTZ_DIR}/{{protein}}/batch_{{batch}}/complete.flag",
            protein=PROTEINS,
            batch=BATCHES
        )

# --------------------------------------------------
# Generate YAML
# --------------------------------------------------

rule generate_yaml:
    input:
        fasta=f"{FASTA_DIR}/{{protein}}.fasta",
        msa=f"{MSA_DIR}/{{protein}}/{{protein}}.a3m"
    output:
        f"{YAML_DIR}/{{protein}}_{{ligand}}.yaml"
    log:
        f"logs/generate_yaml/{{protein}}_{{ligand}}.log"
    params:
        ligand_type=lambda wc: LIGAND_INFO[wc.ligand]["type"],
        ligand_value=lambda wc: LIGAND_INFO[wc.ligand]["value"]
    threads: 1
    resources:
        mem_mb=1000,
        gpu=0,
        gpu_flag=""
    shell:
        """
        set -euo pipefail

        python generate_yaml.py \
            --fasta_file {input.fasta} \
            --msa_file {input.msa} \
            --ligand_id {wildcards.ligand} \
            --ligand_type {params.ligand_type} \
            --ligand_value "{params.ligand_value}" \
            --output_yaml {output}
        """


# --------------------------------------------------
# Run Boltz in batches (5 YAMLs per GPU job)
# --------------------------------------------------

rule run_boltz_batch:
    input:
        lambda wc: expand(
            f"{YAML_DIR}/{wc.protein}_{{ligand}}.yaml",
            ligand=LIGAND_IDS[
                int(wc.batch) * BATCH_SIZE :
                (int(wc.batch) + 1) * BATCH_SIZE
            ]
        )
    output:
        touch(f"{BOLTZ_DIR}/batch_{{protein}}_{{batch}}.flag")
    log:
        f"logs/run_boltz_batch/{{protein}}_{{batch}}.log"
    threads: lambda wc: min(4, BATCH_SIZE)
    resources:
        mem_mb=32000,
        gpu=1,
        gpu_flag="--gres=gpu:h200:1"
    shell:
        """
        scripts/run_boltz_batch.sh \
            {wildcards.protein} \
            {BOLTZ_DIR} \
            {threads} \
            {log} \
            {input:q}

        touch {output}
        """